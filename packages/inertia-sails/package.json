{
  "name": "inertia-sails",
  "version": "1.4.0",
  "description": "The Sails adapter for Inertia.",
  "main": "index.js",
  "sails": {
    "isHook": true,
    "hookName": "inertia"
  },
  "scripts": {
    "check:js": "tsc --allowJs --checkJs --noEmit --skipLibCheck --target ES2022 --module commonjs --noImplicitAny index.js test.js lib/**/*.js tests/**/*.js",
    "test": "npm run check:js && node --test tests/*.test.js tests/**/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sailscastshq/boring-stack.git",
    "directory": "packages/inertia-sails"
  },
  "peerDependencies": {
    "sails": ">=1",
    "sails-flash": ">=0.0.1"
  },
  "keywords": [
    "Inertia",
    "Sails"
  ],
  "author": "Kelvin Omereshone Oghenerhoro <kelvin@sailscasts.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sailscastshq/boring-stack/issues"
  },
  "homepage": "https://github.com/sailscastshq/boring-stack/tree/main/inertia-sails#readme",
  "devDependencies": {}
}
