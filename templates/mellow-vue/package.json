    "@sailshq/socket.io-redis": "^6.1.2",
    "inertia-sails": "^1.5.0",
    "nodemailer": "^6.9.15",
    "sails": "^1.5.14",
    "sails-flash": "^0.0.1",
    "sails-hook-mail": "^0.2.0",
    "sails-hook-organics": "^3.0.0",
    "sails-hook-orm": "^4.0.3",
    "sails-hook-sockets": "^3.0.1",
    "sails-hook-wish": "^1.0.0",
    "vue": "^3.5.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@rsbuild/plugin-vue": "^1.2.8",
    "@tailwindcss/postcss": "^4.1.16",
    "create-sails-generator": "^1.0.0",
    "playwright": "^1.47.1",
    "prettier": "^2.8.8",
    "prettier-plugin-tailwindcss": "^0.4.1",
    "rsbuild-plugin-inertia": "^0.0.1",
    "sails-hook-dev": "^1.3.0",
    "sails-hook-shipwright": "^1.4.0",
    "sails-sqlite": "^0.2.5",
    "sails.io.js": "^1.2.1",
    "socket.io-client": "^4.7.5",
    "sounding": "^0.0.1",
    "tailwindcss": "^4.1.16"
  },
  "scripts": {
    "dev": "node --watch-path=api --watch-path=config app.js",
    "start": "NODE_ENV=production node app.js",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test:unit": "node --test --test-concurrency=1 tests/unit/**/*.test.js",
    "test:functional": "node --test --test-concurrency=1 tests/functional/**/*.test.js",
    "test:e2e": "node --test --test-concurrency=1 tests/e2e/**/*.test.js",
    "test": "npm run test:unit && npm run test:functional && npm run test:e2e"
  },
  "main": "app.js",
  "engines": {
    "node": ">=18.0"
  }
